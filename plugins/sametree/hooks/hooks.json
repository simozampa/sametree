{
  "description": "Share explicit user instructions and proposed Claude Code plans through SameTree.",
  "hooks": {
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node",
            "args": ["${CLAUDE_PLUGIN_ROOT}/hooks/capture-shared-instruction.mjs"],
            "timeout": 5,
            "statusMessage": "Sharing explicit instruction through SameTree"
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "ExitPlanMode",
        "hooks": [
          {
            "type": "command",
            "command": "node",
            "args": ["${CLAUDE_PLUGIN_ROOT}/hooks/publish-plan.mjs"],
            "timeout": 5,
            "statusMessage": "Publishing proposed plan to SameTree"
          }
        ]
      }
    ]
  }
}
